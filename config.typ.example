// Course metadata. Bootstrap copies this to config.typ and fills it in.
//
// All Typst templates import these values via `#import "../config.typ": *`.
// HTML templates and workflows substitute them via {{COURSE_CODE}} etc.

#let course-code = "XXX 0000"            // e.g. "DSAA 3071", "PHYS 2071"
#let course-name = "Course Name"         // e.g. "Theories in Computing"
#let textbook-author = "Author"          // e.g. "Sipser"
#let textbook-title = "Textbook Title"   // e.g. "Introduction to the Theory of Computation"
#let textbook-edition = "1st ed."        // e.g. "3rd ed."
#let instructor = "Instructor Name"
#let institution = "Institution"         // e.g. "HKUST(GZ)"

// Used by the Zulip release workflow. Empty string disables the workflow.
#let zulip-stream = ""                   // e.g. "DSAA3071-2026-Spring"

// Convenience: short reference shown in test/validation footers.
// Defaults to "<author>" — override if you prefer "<author> §3.1" style.
#let textbook-short = textbook-author
